{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos principales para Colibri IDE",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-write",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-create",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-lstat",
    "fs:allow-copy-file",
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DESKTOP" },
        { "path": "$DESKTOP/*" },
        { "path": "$DESKTOP/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/**/*" }
      ]
    }
  ]
}